              "function requireVariable(key) {",
              "  const value = getVariable(key);",
              "  if (!value) {",
              "    throw new Error(`Missing Postman variable: ${key}. Select the Profile Microservices Local environment or fill this variable.`);",
              "  }",
              "  return value;",
              "}",
              "",
              "function signKeyPairRequest(method, path) {",
              "  const keySecret = requireVariable('keyPairSecret');",
              "  const timestamp = new Date().toISOString();",
              "  const message = `${method.toUpperCase()}:${path}:${timestamp}`;",
              "  const signature = CryptoJS.HmacSHA256(message, keySecret).toString(CryptoJS.enc.Hex);",
              "",
              "  pm.collectionVariables.set('keyTimestamp', timestamp);",
              "  pm.collectionVariables.set('keySignature', signature);",
              "}",
              "",
              "signKeyPairRequest('GET', `/get-profile/${pm.collectionVariables.get('profileId')}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile returned', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{basicUser}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{basicPassword}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [
          {
            "key": "x-key-id",
            "value": "{{keyPairId}}"
          },
          {
            "key": "x-key-timestamp",
            "value": "{{keyTimestamp}}"
          },
          {
            "key": "x-key-signature",
            "value": "{{keySignature}}"
          }
        ],
        "url": {
          "raw": "{{queryBaseUrl}}/get-profile/{{profileId}}",
          "host": [
            "{{queryBaseUrl}}"
          ],
          "path": [
            "get-profile",
            "{{profileId}}"
          ]
        },
        "description": "Queries a profile through MS #1. MS #1 signs and calls MS #2 internally."
      },
      "response": []
    },
