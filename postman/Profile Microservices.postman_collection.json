{
  "info": {
    "name": "Profile Microservices",
    "description": "Collection for the BPD technical test profile microservices. Includes Basic Auth, Key Pair HMAC headers, and profile token usage.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "profileId",
      "value": ""
    },
    {
      "key": "profileToken",
      "value": "",
      "type": "secret"
    }
  ],
  "item": [
    {
      "name": "MS #2 - Create Profile",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function getVariable(key) {",
              "  return pm.environment.get(key) || pm.collectionVariables.get(key) || pm.variables.get(key);",
              "}",
              "",
              "function requireVariable(key) {",
              "  const value = getVariable(key);",
              "  if (!value) {",
              "    throw new Error(`Missing Postman variable: ${key}. Select the Profile Microservices Local environment or fill this variable.`);",
              "  }",
              "  return value;",
              "}",
              "",
              "function signKeyPairRequest(method, path) {",
              "  const keySecret = requireVariable('keyPairSecret');",
              "  const timestamp = new Date().toISOString();",
              "  const message = `${method.toUpperCase()}:${path}:${timestamp}`;",
              "  const signature = CryptoJS.HmacSHA256(message, keySecret).toString(CryptoJS.enc.Hex);",
              "",
              "  pm.collectionVariables.set('keyTimestamp', timestamp);",
              "  pm.collectionVariables.set('keySignature', signature);",
              "}",
              "",
              "signKeyPairRequest('POST', '/create-profile');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json.profile && json.profile.id) {",
              "  pm.collectionVariables.set('profileId', json.profile.id);",
              "}",
              "if (json.token) {",
              "  pm.collectionVariables.set('profileToken', json.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{basicUser}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{basicPassword}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          },
          {
            "key": "x-key-id",
            "value": "{{keyPairId}}"
          },
          {
            "key": "x-key-timestamp",
            "value": "{{keyTimestamp}}"
          },
          {
            "key": "x-key-signature",
            "value": "{{keySignature}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ana\",\n  \"lastName\": \"Perez\",\n  \"email\": \"ana.perez{{$timestamp}}@example.com\",\n  \"phone\": \"8095551234\",\n  \"address\": \"Santo Domingo\"\n}"
        },
        "url": {
          "raw": "{{crudBaseUrl}}/create-profile",
          "host": [
            "{{crudBaseUrl}}"
          ],
          "path": [
            "create-profile"
          ]
        },
        "description": "Creates a profile in the CRUD microservice. Stores profileId and profileToken for the next requests."
      },
      "response": []
    },
    {
      "name": "MS #1 - Get Profile",
